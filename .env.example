# Bhaktanjaneya Sweets environment template
# Copy this file to .env.local for local development.
# Only NEXT_PUBLIC_* values are exposed to the browser.

# Storefront
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_WHATSAPP_NUMBER=919999999999
NEXT_PUBLIC_GOOGLE_REVIEWS_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_GOOGLE_OAUTH_ENABLED=false

# Auth
AUTH_TOKEN_SECRET=

# Razorpay
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Optional live reviews and reels
NEXT_PUBLIC_FEATURABLE_WIDGET_ID=
INSTAGRAM_RSS_URL=
GOOGLE_PLACE_ID=
GOOGLE_MAPS_API_KEY=
INSTAGRAM_ACCESS_TOKEN=
