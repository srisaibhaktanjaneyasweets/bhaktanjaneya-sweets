# ─── Bhaktanjaneya Sweets — frontend environment ───────────────────────────
# Copy to .env.local for local development. Only NEXT_PUBLIC_* vars reach the
# browser. Secrets (Razorpay key_secret, OTP provider keys, DB URLs) live ONLY
# on the backend your friend builds — never add them here.

# Business WhatsApp number, international format, digits only (no +, spaces).
NEXT_PUBLIC_WHATSAPP_NUMBER=919999999999

# Public site URL — used for SEO canonical/Open Graph URLs, sitemap & robots.
# Set to your production domain on deploy (e.g. https://bhaktanjaneyasweets.com).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Link to the business's Google reviews / Maps listing. Powers the
# "Read all reviews on Google" button in the homepage reviews section.
# (Curate the review cards themselves in src/lib/google-reviews.ts.)
NEXT_PUBLIC_GOOGLE_REVIEWS_URL=

# Data is loaded from Supabase via the Next.js API routes in src/app/api/.
NEXT_PUBLIC_API_BASE_URL=/api

# Razorpay publishable key id (phase 2). The matching key_secret stays on the
# backend and is used there to create orders and verify signatures.
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Supabase configuration (for local dev put values in .env.local)
# Public URL and anon key used on the client; service role key is server-only
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Razorpay secret (server-only)
RAZORPAY_KEY_SECRET=

# Token signing secret for API auth sessions (server-only). REQUIRED in prod.
AUTH_TOKEN_SECRET=

# Set to "true" to return the OTP code in the API response (local testing only,
# when no SMS provider is wired). Never enable this in a deployed environment.
OTP_DEBUG=

# MSG91 OTP (server-only) — sends, resends, and verifies login OTPs. When both
# are set, OTP login uses MSG91; otherwise it falls back to the local-dev code.
#   1. MSG91 dashboard → OTP → create/approve a DLT OTP template, copy its id.
#   2. Copy your account Auth Key.
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
# Optional: minutes a code stays valid (default 5).
MSG91_OTP_EXPIRY=5

# ─── Free auto-sync sources (no official API, no client account — recommended) ─
# These make the reviews/reels sections fetch live data on the server and render
# it in the site's own carousels. They take priority over the curated fallbacks
# and the official APIs below. Leave blank to keep the hand-curated fallbacks.
#
# Featurable Google Reviews — free, no Google API key, no client login. Sign up
# at featurable.com, search & select the business, create a widget, then copy the
# widget id from the embed (`id="featurable-XXXX"`). We fetch it live via
# https://featurable.com/api/v2/widgets/<id> and re-fetch on every page load.
NEXT_PUBLIC_FEATURABLE_WIDGET_ID=
#
# Instagram reels via a public RSS feed (no Instagram account/login). Create a
# feed from the PUBLIC profile URL at rss.app (or similar) and paste the feed's
# JSON URL here (e.g. https://rss.app/feeds/v1.1/XXXX.json). We map its items to
# reel cards. Server-side only — no NEXT_PUBLIC_ prefix.
INSTAGRAM_RSS_URL=

# ─── Official API Integrations (Server-side fetches) ───────────────────────
# Google Places API (for Loved on Google reviews widget sync)
# 1. Enable Places API in Google Cloud Console
# 2. Get API Key and get your Place ID from Google Place ID Finder
GOOGLE_PLACE_ID=
GOOGLE_MAPS_API_KEY=

# Instagram Basic Display API (for live Instagram Reels carousel sync)
# 1. Create a Meta Developer app & add Instagram Basic Display
# 2. Generate a long-lived User Access Token
INSTAGRAM_ACCESS_TOKEN=

