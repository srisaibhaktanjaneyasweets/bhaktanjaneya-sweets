# ─── Bhaktanjaneya Sweets — frontend environment ───────────────────────────
# Copy to .env.local for local development. Only NEXT_PUBLIC_* vars reach the
# browser. Secrets (Razorpay key_secret, OTP provider keys, DB URLs) live ONLY
# on the backend your friend builds — never add them here.

# Business WhatsApp number, international format, digits only (no +, spaces).
NEXT_PUBLIC_WHATSAPP_NUMBER=919999999999

# Public site URL — used for SEO canonical/Open Graph URLs, sitemap & robots.
# Set to your production domain on deploy (e.g. https://bhaktanjaneyasweets.com).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Data is loaded from Supabase via the Next.js API routes in src/app/api/.
NEXT_PUBLIC_API_BASE_URL=

# Razorpay publishable key id (phase 2). The matching key_secret stays on the
# backend and is used there to create orders and verify signatures.
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Supabase configuration (for local dev put values in .env.local)
# Public URL and anon key used on the client; service role key is server-only
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Razorpay secret (server-only)
RAZORPAY_KEY_SECRET=

# Token signing secret for API auth sessions (server-only)
AUTH_TOKEN_SECRET=
